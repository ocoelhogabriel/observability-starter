<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ocoelhogabriel Observability — Logback Defaults
  =========================================
  Inclua este arquivo no seu logback-spring.xml:
    <include resource="logback-defaults-ocoelhogabriel.xml"/>

  Ele fornece:
  - Conversion rule para masking automático (%mask)
  - Appender OCOELHOGABRIEL_CONSOLE pré-configurado (padrão DEV colorido)
-->
<included>

  <!-- Registra os conversores Spring Boot: %clr (cores ANSI) e %wEx (stack trace) -->
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Registra o converter de masking -->
  <conversionRule conversionWord="mask"
    class="br.com.ocoelhogabriel.observability.masking.MaskingMessageConverter"/>

  <!-- Propriedades injetadas do Spring -->
  <springProperty scope="context" name="appName"
    source="spring.application.name" defaultValue="app"/>
  <springProperty scope="context" name="activeProfile"
    source="spring.profiles.active" defaultValue="default"/>

  <!-- ── Appender CONSOLE DEV (pronto para usar) ──────────────────── -->
  <!--
    IMPORTANTE: %n NÃO pode ficar dentro de <property value="..."/>.
    Quando o Logback expande a propriedade via ${VAR}, o %n já chega como
    texto literal para o PatternLayoutEncoder e não é interpretado como
    newline — resultado: todos os logs ficam na mesma linha.
    O pattern deve ser declarado diretamente no <encoder> para que o
    PatternLayout receba e resolva %n corretamente.
  -->
  <appender name="OCOELHOGABRIEL_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr([${appName:-},%X{traceId:-},%X{spanId:-}]){yellow} %clr({%X{scope:-}}){blue} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %mask(%msg)%n%wEx</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

</included>
